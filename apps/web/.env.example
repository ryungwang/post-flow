# 로컬 개발용. 이 파일을 apps/web/.env.local 로 복사하면 Vite가 자동 로드한다.
# (.env.local 은 gitignore 됨.)

# Google 로그인 클라이언트 ID — 백엔드 GOOGLE_CLIENT_ID 와 동일한 값.
# 비어 있으면 로그인 화면에 "설정 필요" 안내가 표시됨.
VITE_GOOGLE_CLIENT_ID=

# API 프록시 대상(백엔드 주소). 기본 http://localhost:8080
# 백엔드를 다른 포트로 띄우면 여기 맞춰 변경.
VITE_API_PROXY_TARGET=http://localhost:8080
