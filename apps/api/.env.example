# 로컬 개발용 키. 이 파일을 apps/api/.env 로 복사하면 Spring이 자동 로드한다.
# (.env 는 gitignore 됨. 값만 채우면 해당 기능이 바로 동작한다.)

# AI 콘텐츠 생성 (Anthropic Claude) — 없으면 /api/ai/generate 가 401/500
ANTHROPIC_API_KEY=

# Google 로그인 — 백엔드 ID토큰 검증 audience.
# 반드시 프론트 VITE_GOOGLE_CLIENT_ID 와 동일한 값.
GOOGLE_CLIENT_ID=

# Threads(메타) 연동 — OAuth/발행. (Threads 앱 ID/시크릿, FB 앱과 별개)
THREADS_APP_ID=
THREADS_APP_SECRET=
# 로컬 콜백/프론트 리다이렉트는 기본값 사용. 필요 시 오버라이드:
# THREADS_REDIRECT_URI=http://localhost:8080/api/threads/callback
# THREADS_FRONTEND_REDIRECT_URL=http://localhost:5173/settings/threads?threads=connected

# (선택) JWT 서명 시크릿 — 미설정 시 dev 기본값(비보안). prod 는 반드시 주입.
# AUTH_JWT_SECRET=

# Content ROI
# 단축링크(/r/{slug}) 베이스 — 백엔드 공개 주소
# ROI_SHORT_LINK_BASE_URL=http://localhost:8080
# 리드 캡처 랜딩(/lp/{slug}) 베이스 — 프론트 주소
# ROI_FRONTEND_BASE_URL=http://localhost:5173
# 업로드 이미지 로컬 서빙 베이스 (prod 는 S3 public URL 사용)
# STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:8080/files
# 전환 웹훅 HMAC 시크릿은 사용자별(계정 설정에서 발급) — 전역 env 불필요
# 클릭 집계: 동일 IP해시 30분 내 중복 미집계 + 봇 UA 제외 (코드 기본값)

# (선택) DB/Redis — 미설정 시 application-local.yml 기본값(localhost, postflow/postflow)
# DB_USERNAME=postflow
# DB_PASSWORD=postflow
