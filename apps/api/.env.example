# 로컬 개발용 키. 이 파일을 apps/api/.env 로 복사하면 Spring이 자동 로드한다.
# (.env 는 gitignore 됨. 값만 채우면 해당 기능이 바로 동작한다.)

# AI 콘텐츠 생성 (Anthropic Claude) — 없으면 /api/ai/generate 가 401/500
ANTHROPIC_API_KEY=

# Threads(메타) 연동 — OAuth/발행. (Threads 앱 ID/시크릿, FB 앱과 별개)
THREADS_APP_ID=
THREADS_APP_SECRET=
# 로컬 콜백/프론트 리다이렉트는 기본값 사용. 필요 시 오버라이드:
# THREADS_REDIRECT_URI=http://localhost:8080/api/threads/callback
# THREADS_FRONTEND_REDIRECT_URL=http://localhost:5173/settings/threads?threads=connected

# ── 로그인 = synub 통합계정(SSO). 제품은 SSO 발급 JWT를 검증만 한다. ──
# 로컬 기본값(application.yml)으로 동작: SSO_BASE_URL/JWKS=localhost:8090, audience=synub-postflow.
# 운영에서만 오버라이드:
# SSO_BASE_URL=https://accounts.synub.io
# SSO_JWKS_URI=https://accounts.synub.io/.well-known/jwks.json
# SSO_ISSUER=https://accounts.synub.io

# ── 구독 = synub 중앙 빌링. entitlements 조회 + 웹훅 수신. ──
# 로컬 기본값: BILLING_BASE_URL=localhost:8088, service-code=post-flow,
#   SERVICE_API_KEY=local-service-key, BILLING_WEBHOOK_SECRET=local-dev-webhook-secret.
# 운영에서만 오버라이드(빌링과 동일 값 공유):
# BILLING_BASE_URL=https://app.synub.io
# SERVICE_API_KEY=            # 빌링이 발급한 서비스 키(X-Service-Key)
# BILLING_WEBHOOK_SECRET=     # 빌링 app.webhook.secret 과 동일

# Threads OAuth state 서명(내부 전용, 로그인 아님) — 미설정 시 dev 기본값. prod 는 주입.
# AUTH_STATE_SECRET=

# Content ROI
# ROI_SHORT_LINK_BASE_URL=http://localhost:8080     # 단축링크(/r/{slug}) 베이스
# ROI_FRONTEND_BASE_URL=http://localhost:5173        # 리드 랜딩(/lp/{slug}) 베이스
# STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:8080/files
# (전환 웹훅 HMAC은 사용자별 발급 — 전역 env 불필요)

# (선택) DB/Redis — 미설정 시 application-local.yml 기본값(localhost, postflow/postflow)
# DB_USERNAME=postflow
# DB_PASSWORD=postflow
